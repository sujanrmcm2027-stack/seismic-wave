# Web3Forms access key for the contact page
VITE_WEB3FORMS_ACCESS_KEY=your_web3forms_key_here

# Google Gemini API key (if applicable for AI endpoints)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Google Apps Script Web App URL for data persistence (Safe Reports, DYFI, etc.)
VITE_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID_HERE/exec

# API URL for fetching the nationwide safe zones GeoJSON
# Can be a remote endpoint or pointing to the local fallback bundle
VITE_SAFE_ZONES_API_URL=/fallback_safe_zones.json
